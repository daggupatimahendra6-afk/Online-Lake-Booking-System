<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Onlinecamp — Vasota Lake Camping</display-name>

    <!-- ══════════════════════════════════════════════════════════════════════
         CLEAN URL MAPPINGS
         JSP pages are mapped to extension-free URLs.
         e.g. /gallery  →  Gallery.jsp   (user never sees .jsp in address bar)
         Servlet URLs (/Login, /Bookings, /Dashboard etc.) are unchanged.
    ══════════════════════════════════════════════════════════════════════ -->

    <servlet>
        <servlet-name>home</servlet-name>
        <jsp-file>/Main.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>home</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>gallery</servlet-name>
        <jsp-file>/Gallery.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>gallery</servlet-name>
        <url-pattern>/gallery</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>offers</servlet-name>
        <jsp-file>/Offers.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>offers</servlet-name>
        <url-pattern>/offers</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>contact</servlet-name>
        <jsp-file>/Contact.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>contact</servlet-name>
        <url-pattern>/contact</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>book</servlet-name>
        <jsp-file>/Bookings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>book</servlet-name>
        <url-pattern>/book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>login</servlet-name>
        <jsp-file>/Login.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>signup</servlet-name>
        <jsp-file>/SignUp.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>signup</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>logout</servlet-name>
        <jsp-file>/Logout.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>thankyou</servlet-name>
        <jsp-file>/Thankyou.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>thankyou</servlet-name>
        <url-pattern>/thankyou</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════════════════════
         SECURITY: Block direct access to .jsp files, Eclipse project
         extents, git files, build output and all dot-files.
         Users must use clean URLs only.
    ══════════════════════════════════════════════════════════════════════ -->

    <!-- Block direct .jsp access (force clean URLs) -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Raw JSP Files</web-resource-name>
            <url-pattern>*.jsp</url-pattern>
        </web-resource-collection>
        <auth-constraint/>
    </security-constraint>

    <!-- Block Eclipse project extents and dev files -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Eclipse and Dev Files</web-resource-name>
            <url-pattern>/.classpath</url-pattern>
            <url-pattern>/.project</url-pattern>
            <url-pattern>/.settings/*</url-pattern>
            <url-pattern>/.gitignore</url-pattern>
            <url-pattern>/.git/*</url-pattern>
            <url-pattern>/build/*</url-pattern>
            <url-pattern>*.class</url-pattern>
        </web-resource-collection>
        <auth-constraint/>
    </security-constraint>

    <!-- Block all hidden dot-files -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Hidden Dot Files</web-resource-name>
            <url-pattern>/.*</url-pattern>
        </web-resource-collection>
        <auth-constraint/>
    </security-constraint>

    <!-- ══════════════════════════════════════════════════════════════════════
         SESSION CONFIG
    ══════════════════════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <same-site>Strict</same-site>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ══════════════════════════════════════════════════════════════════════
         WELCOME FILES
    ══════════════════════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ══════════════════════════════════════════════════════════════════════
         CUSTOM ERROR PAGES
    ══════════════════════════════════════════════════════════════════════ -->
    <error-page>
        <error-code>403</error-code>
        <location>/error403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error500.jsp</location>
    </error-page>

</web-app>
