<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Onlinecamp — Vasota Lake Camping</display-name>

    <!-- ══════════════════════════════════════════════════════════════════════
         CLEAN URL MAPPINGS
         JSP pages are mapped to extension-free URLs.
         e.g. /gallery  →  Gallery.jsp   (user never sees .jsp in address bar)
         Servlet URLs (/Login, /Bookings, /Dashboard etc.) are unchanged.
    ══════════════════════════════════════════════════════════════════════ -->

    <servlet>
        <servlet-name>home</servlet-name>
        <jsp-file>/Main.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>home</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>gallery</servlet-name>
        <jsp-file>/Gallery.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>gallery</servlet-name>
        <url-pattern>/gallery</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>offers</servlet-name>
        <jsp-file>/Offers.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>offers</servlet-name>
        <url-pattern>/offers</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>contact</servlet-name>
        <jsp-file>/Contact.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>contact</servlet-name>
        <url-pattern>/contact</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>book</servlet-name>
        <jsp-file>/Bookings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>book</servlet-name>
        <url-pattern>/book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>login</servlet-name>
        <jsp-file>/Login.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>signup</servlet-name>
        <jsp-file>/SignUp.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>signup</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>logout</servlet-name>
        <jsp-file>/Logout.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>thankyou</servlet-name>
        <jsp-file>/Thankyou.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>thankyou</servlet-name>
        <url-pattern>/thankyou</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════════════════════
         JAVA SERVLET REGISTRATIONS
         Explicit registration overrides annotation scanning — needed for
         some Eclipse/WTP Tomcat configurations that miss @WebServlet classes.
    ══════════════════════════════════════════════════════════════════════ -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.lake.camping.Login</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/Login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.lake.camping.Dashboard</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/Dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MyBookingsServlet</servlet-name>
        <servlet-class>com.lake.camping.MyBookings</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MyBookingsServlet</servlet-name>
        <url-pattern>/MyBookings</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BookingsServlet</servlet-name>
        <servlet-class>com.lake.camping.Bookings</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingsServlet</servlet-name>
        <url-pattern>/Bookings</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ContactServlet</servlet-name>
        <servlet-class>com.lake.camping.Contact</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactServlet</servlet-name>
        <url-pattern>/Contact</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DisplayBookingServlet</servlet-name>
        <servlet-class>com.lake.camping.DisplayBooking</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DisplayBookingServlet</servlet-name>
        <url-pattern>/DisplayBooking</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DisplayContactServlet</servlet-name>
        <servlet-class>com.lake.camping.DisplayContact</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DisplayContactServlet</servlet-name>
        <url-pattern>/DisplayContact</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SignUpServlet</servlet-name>
        <servlet-class>com.lake.camping.SignUp</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignUpServlet</servlet-name>
        <url-pattern>/SignUp</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddAdminServlet</servlet-name>
        <servlet-class>com.lake.camping.AddAdmin</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddAdminServlet</servlet-name>
        <url-pattern>/AddAdmin</url-pattern>
    </servlet-mapping>

    <!-- ── Gemini AI Proxy — keeps API key server-side ── -->
    <servlet>
        <servlet-name>GeminiProxy</servlet-name>
        <servlet-class>com.lake.camping.GeminiProxy</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GeminiProxy</servlet-name>
        <url-pattern>/GeminiProxy</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════════════════════
         AUTH FILTER — guards all admin-only URLs
    ══════════════════════════════════════════════════════════════════════ -->

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.lake.camping.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/Dashboard</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/DisplayBooking</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/DisplayContact</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/AddAdmin</url-pattern>
    </filter-mapping>

    <!-- ══════════════════════════════════════════════════════════════════════
         SECURITY: Block direct access to .jsp files, Eclipse project
         extents, git files, build output and all dot-files.
         Users must use clean URLs only.
    ══════════════════════════════════════════════════════════════════════ -->





    <!-- ══════════════════════════════════════════════════════════════════════
         SESSION CONFIG
    ══════════════════════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ══════════════════════════════════════════════════════════════════════
         WELCOME FILES
    ══════════════════════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ══════════════════════════════════════════════════════════════════════
         CUSTOM ERROR PAGES
    ══════════════════════════════════════════════════════════════════════ -->
    <error-page>
        <error-code>403</error-code>
        <location>/error403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error500.jsp</location>
    </error-page>

</web-app>
